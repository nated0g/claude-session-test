      else { cls += ' tool'; }\n                div.className = cls;\n                const roleClass = type === 'user' ? 'user-role' : type === 'assistant' ? 'assistant-role' : 'tool-role';\n                let content = msg.message || msg.output || '';\n                if (msg.input) content = JSON.stringify(msg.input, null, 2);\n                div.innerHTML = '<div class=\"role ' + roleClass + '\">' + role + '</div><pre>' + (content || '').replace(/</g,'&lt;') + '</pre>';\n                container.appendChild(div);\n              }\n            </script>\n          </body>\n          </html>\n          HTMLEOF\n          done\n\n      - name: Deploy to gh-pages\n        if: steps.extract.outputs.found == 'true'\n        run: |\n          git config user.name \"github-actions[bot]\"\n          git config user.email \"github-actions[bot]@users.noreply.github.com\"\n          git fetch origin gh-pages\n          git checkout gh-pages\n          PR_NUM=${{ github.event.pull_request.number }}\n          cp -r deploy/pr/ pr/ 2>/dev/null || true\n          git add pr/\n          git commit -m \"Add session pages for PR #${PR_NUM}\" || echo \"No changes to commit\"\n          git push origin gh-pages\n\n      - name: Comment on PR\n        if: steps.extract.outputs.found == 'true'\n        uses: actions/github-script@v7\n        with:\n          script: |\n            const fs = require('fs');\n            const prNum = context.issue.number;\n\n            // Get GitHub Pages URL\n            const { data: pages } = await github.rest.repos.getPages({\n              owner: context.repo.owner,\n              repo: context.repo.repo,\n            });\n            const baseUrl = pages.html_url.replace(/\\/$/, '');\n\n            const files = fs.readdirSync('sessions');\n            let body = `### Claude Code Sessions\\n\\n`;\n            body += `Found ${files.length} session(s) attached to commits in this PR.\\n\\n`;\n            for (const f of files) {\n             